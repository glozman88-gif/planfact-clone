# Скопируйте в .env и заполните. Файл .env в git НЕ коммитим.
DATABASE_URL=postgresql+asyncpg://planfact:CHANGEME@127.0.0.1:5432/planfact
# Секрет для подписи JWT (сгенерируйте: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_RANDOM_HEX
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=10080
# CORS: список origin'ов фронтенда через запятую (для локальной разработки)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Каталог для загруженных файлов (вложения)
UPLOAD_DIR=./uploads
# Базовая валюта по умолчанию при создании компании
DEFAULT_CURRENCY=RUB
