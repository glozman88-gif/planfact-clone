# Конфигурация для docker compose. Скопируйте в .env и заполните:
#   cp .env.example .env
# Файл .env в git НЕ коммитится (см. .gitignore).

# Пароль пользователя БД (postgres). Задайте свой.
POSTGRES_PASSWORD=change_me_db_password

# Секрет для подписи JWT. Сгенерируйте: openssl rand -hex 32
JWT_SECRET=change_me_to_random_hex

# Учётка администратора (создаётся при первом запуске). СМЕНИТЕ пароль!
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin

# 1 — создать демокомпанию с примерами операций; 0 — пустая база
SEED_DEMO=1

# Порт, на котором приложение будет доступно на сервере (http://IP:APP_PORT)
APP_PORT=8095

# Кол-во воркеров uvicorn
UVICORN_WORKERS=2
