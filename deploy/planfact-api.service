[Unit]
Description=PlanFact-clone API (FastAPI/uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=planfact
Group=planfact
WorkingDirectory=/opt/planfact/backend
EnvironmentFile=/opt/planfact/backend/.env
Environment=FRONTEND_DIST=/opt/planfact/frontend/dist
ExecStart=/opt/planfact/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8095 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
